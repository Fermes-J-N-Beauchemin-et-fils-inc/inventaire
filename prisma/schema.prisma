generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id
  name           String
  email          String    @unique
  emailVerified  Boolean   @default(false)
  image          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  failedAttempts Int       @default(0)
  lockoutUntil   DateTime?
  role           String    @default("admin")
  sessions       Session[]
  accounts       Account[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ---------------------------------------------------------
// 1. Core Models (Corrected Syntax & Relations)
// ---------------------------------------------------------

model Food {
  id           Int     @id @default(autoincrement())
  name         String
  common_name  String?
  unit_type_id Int
  is_active    Boolean @default(true)

  // Current values to be snapshot-ed
  price_per_ms  Float @default(0)
  price_per_tqs Float @default(0)
  ms_percentage Float @default(0)

  // Relations
  unit_type Unit_type     @relation(fields: [unit_type_id], references: [id])
  storages  FoodStorage[]

  // Reverse relations required by Prisma
  daily_servings     DailyServing[]
  deliveries         Delivery[]
  sales              Sale[]
  contracts          Contract[]
  sale_contracts     SaleContract[]
  food_snapshots     FoodSnapshot[]
  stock_transactions StockTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("food")
}

model FoodStorage {
  food_id       Int
  storage_id    Int
  current_stock Float @default(0)

  food    Food    @relation(fields: [food_id], references: [id], onDelete: Cascade)
  storage Storage @relation(fields: [storage_id], references: [id], onDelete: Cascade)

  @@id([food_id, storage_id])
  @@map("food_storage")
}

model Group {
  id                Int     @id @default(autoincrement())
  name              String
  real_animal_count Int     @default(0)
  animals_fed       Int     @default(0)
  notes             String?
  important_notes   String?
  performance_index Float   @default(1.0)
  weather           String?
  season            String?
  target_ms_per_cow Float?
  category          String  @default("Autres")
  summer_two_meals  Boolean @default(false)

  mix_batch_id Int?
  mix_order    Int?
  tour1_order  Int? // Persist UI order for tour 1
  tour2_order  Int? // Persist UI order for tour 2
  aliments_order Json? // Persist UI order for ingredients

  daily_servings            DailyServing[]
  referenced_by_servings    DailyServing[]            @relation("GroupReference")
  group_snapshots           GroupSnapshot[]
  mix_batch                 MixBatch?                 @relation(fields: [mix_batch_id], references: [id])
  groupPerformanceHistories GroupPerformanceHistory[]
  stockTransactions         StockTransaction[]

  @@map("group")
}

model MixBatch {
  id               Int      @id @default(autoincrement())
  name             String
  summer_two_meals Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  aliments_order   Json? // Persist UI order for ingredients

  groups Group[]

  @@map("mix_batch")
}

model DailyServing {
  id                  Int   @id @default(autoincrement())
  food_id             Int?
  group_id            Int
  daily_kg_serving_ms Float

  is_manual            Boolean @default(false)
  manual_name          String?
  manual_ms_percentage Float?
  manual_qty_tqs       Float?
  is_top_dress         Boolean @default(false)

  food  Food? @relation(fields: [food_id], references: [id])
  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)

  reference_group_id Int?
  reference_group    Group? @relation("GroupReference", fields: [reference_group_id], references: [id])

  @@map("daily_serving")
}

model Supplier {
  id           Int     @id @default(autoincrement())
  name         String
  phone_number String
  address      String
  email        String
  logo         String?
  url          String?
  faviconUrl   String?
  is_active    Boolean @default(true)

  contracts  Contract[]
  deliveries Delivery[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("supplier")
}

model Delivery {
  id                Int       @id @default(autoincrement())
  supplier_id       Int?
  food_id           Int
  quantity_received Float
  date_expected     DateTime
  date_delivered    DateTime?

  food                  Food                  @relation(fields: [food_id], references: [id])
  supplier              Supplier?             @relation(fields: [supplier_id], references: [id])
  delivery_subcontracts DeliverySubContract[]

  @@map("delivery")
}

model Contract {
  id           Int      @id @default(autoincrement())
  name         String
  supplier_id  Int
  food_id      Int
  total_kg     Float
  price_per_kg Float
  date_start   DateTime
  date_end     DateTime
  is_active    Boolean  @default(true)

  supplier      Supplier      @relation(fields: [supplier_id], references: [id])
  food          Food          @relation(fields: [food_id], references: [id])
  sub_contracts SubContract[]

  @@map("contract")
}

model SubContract {
  id                 Int     @id @default(autoincrement())
  contract_id        Int
  name               String // ex: "Janvier 2026"
  custom_id          String? // ex: "C34"
  expected_kg        Float
  kg_left_to_deliver Float

  contract             Contract              @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  delivery_allocations DeliverySubContract[]

  @@map("sub_contract")
}

model DeliverySubContract {
  delivery_id     Int
  sub_contract_id Int
  quantity        Float

  delivery     Delivery    @relation(fields: [delivery_id], references: [id], onDelete: Cascade)
  sub_contract SubContract @relation(fields: [sub_contract_id], references: [id], onDelete: Cascade)

  @@id([delivery_id, sub_contract_id])
  @@map("delivery_sub_contract")
}

// ---------------------------------------------------------
// 1.5 Sales Models (Ventes)
// ---------------------------------------------------------

model Client {
  id           Int     @id @default(autoincrement())
  name         String
  phone_number String
  address      String
  email        String
  logo         String?
  url          String?
  faviconUrl   String?
  is_active    Boolean @default(true)

  contracts SaleContract[]
  sales     Sale[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("client")
}

model Sale {
  id            Int       @id @default(autoincrement())
  client_id     Int?
  food_id       Int
  quantity_sold Float
  date_expected DateTime
  date_sold     DateTime?

  food              Food                        @relation(fields: [food_id], references: [id])
  client            Client?                     @relation(fields: [client_id], references: [id])
  sale_subcontracts SaleSubContractAllocation[]

  @@map("sale")
}

model SaleContract {
  id           Int      @id @default(autoincrement())
  name         String
  client_id    Int
  food_id      Int
  total_kg     Float
  price_per_kg Float
  date_start   DateTime
  date_end     DateTime
  is_active    Boolean  @default(true)

  client        Client            @relation(fields: [client_id], references: [id])
  food          Food              @relation(fields: [food_id], references: [id])
  sub_contracts SaleSubContract[]

  @@map("sale_contract")
}

model SaleSubContract {
  id                 Int     @id @default(autoincrement())
  sale_contract_id   Int
  name               String // ex: "Janvier 2026"
  custom_id          String? // ex: "C34"
  expected_kg        Float
  kg_left_to_deliver Float

  contract         SaleContract                @relation(fields: [sale_contract_id], references: [id], onDelete: Cascade)
  sale_allocations SaleSubContractAllocation[]

  @@map("sale_sub_contract")
}

model SaleSubContractAllocation {
  sale_id              Int
  sale_sub_contract_id Int
  quantity             Float

  sale              Sale            @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  sale_sub_contract SaleSubContract @relation(fields: [sale_sub_contract_id], references: [id], onDelete: Cascade)

  @@id([sale_id, sale_sub_contract_id])
  @@map("sale_sub_contract_allocation")
}

model Storage {
  id           Int     @id @default(autoincrement())
  name         String
  max_capacity Int
  is_active    Boolean @default(true)

  food_storages      FoodStorage[]
  stock_transactions StockTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("storage")
}

model Unit_type {
  id           Int    @id @default(autoincrement())
  name         String
  ration_to_kg Float

  foods Food[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("unit")
}

// ---------------------------------------------------------
// 2. Snapshots & Transactions (New additions)
// ---------------------------------------------------------

model FoodSnapshot {
  id          Int      @id @default(autoincrement())
  food_id     Int
  recorded_at DateTime @default(now())

  ms_percentage Float
  price_per_ms  Float
  price_per_tqs Float

  food Food @relation(fields: [food_id], references: [id], onDelete: Cascade)

  @@map("food_snapshot")
}

model StockTransaction {
  id               Int      @id @default(autoincrement())
  food_id          Int
  storage_id       Int? // Optional for older transactions or if not silo-specific
  pushed_ration_id Int? // Link to a pushed ration for rollback
  group_id         Int? // Link to the specific group fed (for undo)
  quantity         Float // Negative for consumption, positive for delivery/adjustment
  transaction_type String // "CONSUMPTION", "DELIVERY", "ADJUSTMENT"
  financial_cost   Float? // Total cost associated with this transaction (useful for historical accounting)
  recorded_at      DateTime @default(now())

  food          Food          @relation(fields: [food_id], references: [id], onDelete: Cascade)
  storage       Storage?      @relation(fields: [storage_id], references: [id], onDelete: Cascade)
  pushed_ration PushedRation? @relation(fields: [pushed_ration_id], references: [id], onDelete: Cascade)
  group         Group?        @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@map("stock_transaction")
}

model GroupSnapshot {
  id          Int      @id @default(autoincrement())
  group_id    Int
  recorded_at DateTime @default(now())

  real_animal_count Int
  animals_fed       Int
  performance_index Float
  weather           String?
  season            String?

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@map("group_snapshot")
}

model PushedRation {
  id             Int      @id @default(autoincrement())
  date           DateTime @default(now())
  status         String   @default("EN_COURS") // EN_COURS, TERMINEE
  groups_total   Int
  groups_done    Int      @default(0)
  payload        Json // Le contenu figé de la ration (groupes, aliments, quantités)
  completed_keys Json? // Liste des clés de groupes terminés (ex: ["g1", "taries"])

  stock_transactions        StockTransaction[]
  financial_transactions    FinancialTransaction[]
  groupPerformanceHistories GroupPerformanceHistory[]

  @@map("pushed_ration")
}

// ---------------------------------------------------------
// 3. Financials & Comptabilité (New additions)
// ---------------------------------------------------------

model MilkSale {
  id              Int      @id @default(autoincrement())
  date            DateTime
  liters          Float
  total_revenue   Float
  fat_percent     Float?
  protein_percent Float?

  @@map("milk_sale")
}

model FinancialTransaction {
  id               Int      @id @default(autoincrement())
  date             DateTime
  type             String // "IN" (Revenu) ou "OUT" (Dépense)
  category         String // ex: "Vétérinaire", "Électricité", "Vente Animaux"
  amount           Float
  description      String?
  pushed_ration_id Int?

  pushed_ration PushedRation? @relation(fields: [pushed_ration_id], references: [id], onDelete: Cascade)

  @@map("financial_transaction")
}

model GroupPerformanceHistory {
  id               Int      @id @default(autoincrement())
  group_id         Int
  date             DateTime
  pushed_ration_id Int?

  cows_fed     Int
  total_kg_ms  Float
  total_kg_tqs Float
  total_cost   Float

  group         Group         @relation(fields: [group_id], references: [id], onDelete: Cascade)
  pushed_ration PushedRation? @relation(fields: [pushed_ration_id], references: [id], onDelete: Cascade)

  @@index([group_id, date])
  @@map("group_performance_history")
}
