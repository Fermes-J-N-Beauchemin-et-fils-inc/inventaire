generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id
  name           String
  email          String    @unique
  emailVerified  Boolean   @default(false)
  image          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  failedAttempts Int       @default(0)
  lockoutUntil   DateTime?
  role           String    @default("admin")
  sessions       Session[]
  accounts       Account[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ---------------------------------------------------------
// 1. Core Models (Corrected Syntax & Relations)
// ---------------------------------------------------------

model Food {
  id           Int     @id @default(autoincrement())
  name         String
  common_name  String?
  unit_type_id Int
  is_active    Boolean @default(true)

  // Current values to be snapshot-ed
  price_per_ms  Float @default(0)
  price_per_tqs Float @default(0)
  ms_percentage Float @default(0)

  // Relations
  unit_type Unit_type     @relation(fields: [unit_type_id], references: [id])
  storages  FoodStorage[]

  // Reverse relations required by Prisma
  daily_servings     DailyServing[]
  deliveries         Delivery[]
  contracts          Contract[]
  food_snapshots     FoodSnapshot[]
  stock_transactions StockTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("food")
}

model FoodStorage {
  food_id       Int
  storage_id    Int
  current_stock Float @default(0)

  food    Food    @relation(fields: [food_id], references: [id], onDelete: Cascade)
  storage Storage @relation(fields: [storage_id], references: [id], onDelete: Cascade)

  @@id([food_id, storage_id])
  @@map("food_storage")
}

model Group {
  id                Int     @id @default(autoincrement())
  name              String
  real_animal_count Int
  animals_fed       Int
  notes             String?
  important_notes   String?
  performance_index Float
  weather           String?
  season            String?

  daily_servings  DailyServing[]
  group_snapshots GroupSnapshot[]

  @@map("group")
}

model DailyServing {
  id                  Int   @id @default(autoincrement())
  food_id             Int
  group_id            Int
  daily_kg_serving_ms Float

  food  Food  @relation(fields: [food_id], references: [id])
  group Group @relation(fields: [group_id], references: [id])

  @@map("daily_serving")
}

model Supplier {
  id           Int     @id @default(autoincrement())
  name         String
  phone_number String
  address      String
  email        String
  logo         String?
  url          String?
  faviconUrl   String?
  is_active    Boolean @default(true)

  contracts  Contract[]
  deliveries Delivery[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("supplier")
}

model Delivery {
  id                Int       @id @default(autoincrement())
  supplier_id       Int?
  food_id           Int
  quantity_received Float
  date_expected     DateTime
  date_delivered    DateTime?

  food                  Food                  @relation(fields: [food_id], references: [id])
  supplier              Supplier?             @relation(fields: [supplier_id], references: [id])
  delivery_subcontracts DeliverySubContract[]

  @@map("delivery")
}

model Contract {
  id           Int      @id @default(autoincrement())
  name         String
  supplier_id  Int
  food_id      Int
  total_kg     Float
  price_per_kg Float
  date_start   DateTime
  date_end     DateTime
  is_active    Boolean  @default(true)

  supplier      Supplier      @relation(fields: [supplier_id], references: [id])
  food          Food          @relation(fields: [food_id], references: [id])
  sub_contracts SubContract[]

  @@map("contract")
}

model SubContract {
  id                 Int    @id @default(autoincrement())
  contract_id        Int
  name               String // ex: "Janvier 2026"
  expected_kg        Float
  kg_left_to_deliver Float

  contract             Contract              @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  delivery_allocations DeliverySubContract[]

  @@map("sub_contract")
}

model DeliverySubContract {
  delivery_id     Int
  sub_contract_id Int
  quantity        Float

  delivery     Delivery    @relation(fields: [delivery_id], references: [id], onDelete: Cascade)
  sub_contract SubContract @relation(fields: [sub_contract_id], references: [id], onDelete: Cascade)

  @@id([delivery_id, sub_contract_id])
  @@map("delivery_sub_contract")
}

model Storage {
  id           Int     @id @default(autoincrement())
  name         String
  max_capacity Int
  is_active    Boolean @default(true)

  food_storages      FoodStorage[]
  stock_transactions StockTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("storage")
}

model Unit_type {
  id           Int    @id @default(autoincrement())
  name         String
  ration_to_kg Float

  foods Food[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("unit")
}

// ---------------------------------------------------------
// 2. Snapshots & Transactions (New additions)
// ---------------------------------------------------------

model FoodSnapshot {
  id          Int      @id @default(autoincrement())
  food_id     Int
  recorded_at DateTime @default(now())

  ms_percentage Float
  price_per_ms  Float
  price_per_tqs Float

  food Food @relation(fields: [food_id], references: [id], onDelete: Cascade)

  @@map("food_snapshot")
}

model StockTransaction {
  id               Int      @id @default(autoincrement())
  food_id          Int
  storage_id       Int? // Optional for older transactions or if not silo-specific
  quantity         Float // Negative for consumption, positive for delivery/adjustment
  transaction_type String // "CONSUMPTION", "DELIVERY", "ADJUSTMENT"
  recorded_at      DateTime @default(now())

  food    Food     @relation(fields: [food_id], references: [id], onDelete: Cascade)
  storage Storage? @relation(fields: [storage_id], references: [id], onDelete: Cascade)

  @@map("stock_transaction")
}

model GroupSnapshot {
  id          Int      @id @default(autoincrement())
  group_id    Int
  recorded_at DateTime @default(now())

  real_animal_count Int
  animals_fed       Int
  performance_index Float
  weather           String?
  season            String?

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@map("group_snapshot")
}

model PushedRation {
  id             Int      @id @default(autoincrement())
  date           DateTime @default(now())
  status         String   @default("EN_COURS") // EN_COURS, TERMINEE
  groups_total   Int
  groups_done    Int      @default(0)
  payload        Json // Le contenu figé de la ration (groupes, aliments, quantités)
  completed_keys Json? // Liste des clés de groupes terminés (ex: ["g1", "taries"])

  @@map("pushed_ration")
}
